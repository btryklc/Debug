import math

def compute_all(bits):
    N = len(bits)
    f = {}
    
    if N == 0:
        return f
    
    f['p1'] = sum(bits) / N
    
    for w in [3, 5, 7, 10, 15, 20, 30, 50]:
        if w <= N:
            f[f'son{w}'] = sum(bits[:w]) / w
    
    for w in [5, 7, 10, 15, 20]:
        if w <= N:
            ch = sum(1 for i in range(w-1) if bits[i] != bits[i+1])
            f[f'vol{w}'] = ch / (w - 1)
    
    for w in [3, 5, 7]:
        if w <= N:
            alt = sum(1 for i in range(w-1) if bits[i] != bits[i+1])
            f[f'zig{w}'] = alt / (w - 1)
    
    runs = 1
    for i in range(1, N):
        if bits[i] != bits[i-1]: 
            runs += 1
    f['runs'] = runs
    f['avg_run'] = N / runs if runs > 0 else N
    
    sv = bits[0]
    sl = 0
    for b in bits:
        if b == sv: 
            sl += 1
        else: 
            break
    f['streak_len'] = sl
    f['streak_val'] = sv
    
    for ng in range(2, 8):
        if ng >= N: 
            continue
        pat = tuple(bits[:ng])
        c0, c1 = 0, 0
        for i in range(ng, N):
            w = tuple(bits[i-ng:i])
            if w == pat:
                if i < N:
                    c1 += bits[i]
                    c0 += 1 - bits[i]
        t = c0 + c1
        f[f'pat{ng}_p1'] = c1/t if t > 0 else 0.5
        f[f'pat{ng}_n'] = t
    
    for s, l in [(5,10), (5,20), (5,30), (10,20), (10,30)]:
        if l <= N:
            f[f'mom_{s}_{l}'] = f.get(f'son{s}', 0.5) - f.get(f'son{l}', 0.5)
    
    f['local_vs_global_5'] = f.get('son5', 0.5) - f['p1']
    f['local_vs_global_10'] = f.get('son10', 0.5) - f['p1']
    
    block_sums = []
    for i in range(0, N-7, 8):
        block_sums.append(sum(bits[i:i+8]))
    if len(block_sums) >= 2:
        f['block_trend'] = block_sums[0] - block_sums[1]
    else:
        f['block_trend'] = 0
    
    mean = sum(bits) / N
    den = sum((b - mean)**2 for b in bits)
    for lag in [1, 2, 3, 5, 7, 10]:
        if den > 0 and lag < N:
            num = sum((bits[i]-mean)*(bits[i+lag]-mean) for i in range(N-lag))
            f[f'ac{lag}'] = num / den
        else:
            f[f'ac{lag}'] = 0
    
    return f

RULES = [
    ("R01: Son-3 > 0.5",          "son3",              ">",  0.5000, 0.78),
    ("R02: Son-5 > 0.5",          "son5",              ">",  0.5000, 0.72),
    ("R03: Lokal>Global(5)",       "local_vs_global_5", ">",  0.0625, 0.72),
    ("R04: pat3_n < 12.5",        "pat3_n",            "<",  12.500, 0.70),
    ("R05: Mom(5,30) > 0.15",     "mom_5_30",          ">",  0.1500, 0.70),
    ("R06: Mom(5,10) > 0.1",      "mom_5_10",          ">",  0.1000, 0.68),
    ("R07: Mom(5,20) > 0.15",     "mom_5_20",          ">",  0.1500, 0.65),
    ("R08: Zig(3) > 0.75",        "zig3",              ">",  0.7500, 0.60),
    ("R09: BlockTrend > 1",       "block_trend",       ">",  1.0000, 0.62),
    ("R10: vol10 < 0.5",          "vol10",             "<",  0.5000, 0.58),
    ("R11: pat4_p1 > 0.33",       "pat4_p1",           ">",  0.3333, 0.58),
    ("R12: avg_run > 2.0",        "avg_run",           ">",  2.0078, 0.57),
    ("R13: vol7 < 0.67",          "vol7",              "<",  0.6667, 0.57),
]

seen = set()
unique_rules = []
for r in RULES:
    key = (r[1], r[2], r[3])
    if key not in seen:
        seen.add(key)
        unique_rules.append(r)

def make_prediction(bits, debug=False):
    f = compute_all(bits)
    N = len(bits)
    
    votes_1 = 0.0
    votes_0 = 0.0
    rule_count_1 = 0
    rule_count_0 = 0
    rule_details = []
    
    for name, feat_key, op, threshold, weight in unique_rules:
        val = f.get(feat_key)
        if val is None:
            continue
        
        if op == ">":
            pred = 1 if val > threshold else 0
        else:
            pred = 1 if val < threshold else 0
        
        if pred == 1:
            votes_1 += weight
            rule_count_1 += 1
        else:
            votes_0 += weight
            rule_count_0 += 1
        
        rule_details.append((name, val, threshold, pred, weight))
    
    if debug:
        print(f"\n📊 STANDART KURALLAR:")
        print(f"   votes_1 = {votes_1:.2f}, votes_0 = {votes_0:.2f}")
    
    contrarian_active = False
    contrarian_reason = None
    
    if votes_0 > votes_1 * 1.5:
        if debug:
            print(f"\n✓ Override şartı: {votes_0:.2f} > {votes_1*1.5:.2f}")
        
        if f['p1'] < 0.15:
            votes_1 = 10.0
            votes_0 = 1.0
            contrarian_active = True
            contrarian_reason = "Duragan 0 sistemi"
            if debug:
                print(f"   → p1={f['p1']:.4f} < 0.15: Override 1!")
        
        elif f['p1'] > 0.85:
            votes_0 = 10.0
            votes_1 = 1.0
            contrarian_active = True
            contrarian_reason = "Duragan 1 sistemi"
            if debug:
                print(f"   → p1={f['p1']:.4f} > 0.85: Override 0!")
    else:
        if debug:
            print(f"\n❌ Override şartı SAĞLANMADı")
    
    if votes_0 > votes_1 and f.get('son5', 0.5) > 0.5:
        if debug:
            print(f"\n⚙️ Son5 reversal: son5={f.get('son5', 0.5):.2f} > 0.5 ve votes_0 > votes_1")
        votes_1 += 3.0
        votes_0 -= 1.0
        if not contrarian_active:
            contrarian_reason = "Son 5 bit yuksek"
    
    elif votes_1 > votes_0 and f.get('son5', 0.5) < 0.4:
        if debug:
            print(f"\n⚙️ Son5 reversal: son5={f.get('son5', 0.5):.2f} < 0.4 ve votes_1 > votes_0")
        votes_0 += 3.0
        votes_1 -= 1.0
        if not contrarian_active:
            contrarian_reason = "Son 5 bit dusuk"
    
    if debug:
        print(f"\n📊 FINAL:")
        print(f"   votes_1 = {votes_1:.2f}, votes_0 = {votes_0:.2f}")
    
    total_w = votes_1 + votes_0
    p1 = votes_1 / total_w if total_w > 0 else 0.5
    final_pred = 1 if p1 > 0.5 else 0
    confidence = max(p1, 1 - p1)
    
    return {
        'prediction': final_pred,
        'p1': p1,
        'confidence': confidence,
        'contrarian_active': contrarian_active,
        'contrarian_reason': contrarian_reason,
        'rule_details': rule_details,
        'features': f,
        'votes_1': votes_1,
        'votes_0': votes_0
    }

veri = "000000000000000000000001100000000000000000000000000000000000000010000000000010000100000000000000000000000000000000000000000001000"
bits = [int(b) for b in veri]
print(f"VERİ: {veri[:60]}...")
print(f"Global p1: %{100*sum(bits)/len(bits):.2f}")
print(f"Son 5: {veri[:5]}")
print(f"Son 10: {veri[:10]}")

result = make_prediction(bits, debug=True)
print(f"\n{'='*80}")
print(f"SONUÇ: {result['prediction']}")
